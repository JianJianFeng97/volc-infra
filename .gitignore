# -----------------------------------------------------------------------
# OS / editor
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo

# -----------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------
# Local .terraform directories (provider plugins, modules cache)
**/.terraform/
.terraform/

# Terraform state files – never commit state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output files
*.tfplan

# Variable files that may contain secrets.
# terraform.tfvars (which holds only non-secret defaults) is
# explicitly tracked via the negation rule below.
*.tfvars
*.tfvars.json
!terraform.tfvars

# Terraform lock file is intentionally NOT ignored (should be committed)
# .terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

